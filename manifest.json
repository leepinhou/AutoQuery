{
	"manifest_version": 3,
	"name": "Auto Query 開發版",
	"version": "1.0",
	"description": "自動查詢指定網址的訊息",
	"icons": {
		"16": "icons/Init.PNG",
		"48": "icons/Login-48.PNG",
		"128": "icons/Login-128.PNG"
	},
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "初始化......",
		"default_icon": "icons/Init.PNG"
	},
	"options_page": "options.html",
	//--不了解，先停用
	"permissions": [
		"tabs", "notifications"
	],
	"host_permissions": [
		"http://*/*"
	]
}
